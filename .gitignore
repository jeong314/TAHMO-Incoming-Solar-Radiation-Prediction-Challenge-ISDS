runs/v14.2/
runs/v20.0_physical_preprocessing/
runs/v25.1_sarah3_audit/
runs/v25.6_sarah3_multi_day_pilot/

# Large reproduction artifacts copied next to the v28.0 script at runtime.
# They are documented in runs/v28.0_sharing/data/ARTIFACT_MANIFEST.csv.
runs/v28.0_sharing/*.csv
runs/v28.0_sharing/metrics*.json
runs/v28.0_sharing/V28_0_METHOD_SUMMARY.md
runs/v28.0_sharing/train.log
runs/v28.0_sharing/diagnostics/
runs/v28.0_sharing/submission_candidates/

# Keep curated lightweight reference artifacts.
!runs/v28.0_sharing/data/
