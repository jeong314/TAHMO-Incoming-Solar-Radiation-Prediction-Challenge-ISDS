# Python/runtime caches
__pycache__/
*.py[cod]
.pytest_cache/

# Local environments
.venv/
venv/

# Credentials and local external-data caches
*.local.json
data_external/
runs/**/data/
runs/**/raw/
runs/**/raw_daily/
runs/**/cams_raw/
runs/**/nasa_power_raw/
